#!/usr/bin/env bash
# Production-grade Go pre-commit hook (Maximum Safe Automation)

set -e

# Ensure Go tools path
export PATH="/home/user/workspace/go/bin:/usr/local/go/bin:$PATH"

echo "================================================="
echo "🔍 Running pre-commit checks..."
echo "================================================="

# STAGE 1: AUTO-FIX (Safe automatic code formatting & fixing)

# 1. Format Go code (gofmt -s)
echo "[1/6] Formatting code (gofmt -s)..."
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [[ -n "$STAGED_GO_FILES" ]]; then
    gofmt -s -w $STAGED_GO_FILES
fi

# 2. Run linter auto-fix if golangci-lint is available
if [[ -f "go.mod" ]] && command -v golangci-lint >/dev/null 2>&1; then
    echo "[2/6] Running golangci-lint --fix..."
    golangci-lint run --fix --timeout 2m || echo "⚠️  Some linter warnings require manual attention."
fi

# 3. Check go.mod and go.sum synchronization
if [[ -f "go.mod" ]]; then
    echo "[3/6] Running go mod tidy..."
    go mod tidy
fi

# Re-stage any files modified by auto-fixers
if [[ -n "$STAGED_GO_FILES" ]] || [[ -f "go.mod" ]]; then
    echo "[4/6] Re-staging auto-fixed files..."
    git add -u
fi

# STAGE 2: VERIFICATION & TESTING (Strict checks for code safety)

# 5. Static analysis with go vet
if [[ -f "go.mod" ]]; then
    echo "[5/6] Running go vet..."
    go vet ./...
fi

# 6. Fast unit testing
if [[ -f "go.mod" ]]; then
    echo "[6/6] Running unit tests (go test -short)..."
    go test -short ./...
fi

echo "================================================="
echo "✅ All pre-commit checks passed successfully!"
echo "================================================="
exit 0

